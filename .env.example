# Server Configuration
IDP_SERVER_PORT=8080

# Database Configuration
IDP_DATABASE_HOST=localhost
IDP_DATABASE_PORT=5432
IDP_DATABASE_USER=postgres
IDP_DATABASE_PASSWORD=postgres
IDP_DATABASE_NAME=idp_api
IDP_DATABASE_SSLMODE=disable

# Authentication
IDP_AUTH_JWT_SECRET=change-me-in-production

# CORS Configuration (comma-separated)
IDP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
IDP_CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH
IDP_CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Request-ID
IDP_CORS_ALLOW_CREDENTIALS=true

# Kubernetes Configuration
IDP_KUBERNETES_IN_CLUSTER=false
IDP_KUBERNETES_KUBECONFIG_PATH=~/.kube/config

# ArgoCD Configuration
IDP_ARGOCD_BASE_URL=https://argocd.example.com
IDP_ARGOCD_TOKEN=
